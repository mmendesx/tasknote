<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Electron's V8 JIT needs writable-executable memory, which the hardened
       runtime forbids by default. Without these the app crashes on launch. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- better-sqlite3 is an unsigned .node addon loaded at runtime. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- The embedded API binds a loopback port and the renderer connects to it. -->
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>
</dict>
</plist>

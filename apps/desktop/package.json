{
  "name": "@tasknote/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "TaskNote Electron desktop shell",
  "author": "Matheus Mendes <matheushenriquesad@gmail.com>",
  "main": "dist/main.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "dev": "electron .",
    "typecheck": "tsc --noEmit",
    "build:package": "electron-builder --publish never",
    "smoke": "node scripts/smoke.js",
    "smoke:appimage": "bash scripts/smoke-appimage.sh"
  },
  "dependencies": {
    "@tasknote/api": "workspace:*",
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.0"
  }
}

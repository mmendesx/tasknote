{
  "name": "@tasknote/api",
  "version": "0.1.0",
  "private": true,
  "description": "TaskNote NestJS API (port 3001)",
  "main": "dist/bootstrap.js",
  "types": "dist/bootstrap.d.ts",
  "exports": {
    ".": {
      "types": "./dist/bootstrap.d.ts",
      "default": "./dist/bootstrap.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist && find src \\( -name '*.js' -o -name '*.js.map' -o -name '*.d.ts' -o -name '*.d.ts.map' \\) -delete",
    "predev": "pnpm clean",
    "dev": "nest start --watch",
    "prebuild": "pnpm clean",
    "build": "tsc && tsc-alias",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/typeorm": "^10.0.2",
    "@tasknote/shared": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "nestjs-zod": "^3.0.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@swc/core": "^1.15.40",
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.7.1",
    "typescript": "^5.4.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^1.4.0"
  }
}

{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "paths": {
      "@tasknote/shared": ["packages/shared/src/index.ts"],
      "@tasknote/shared/*": ["packages/shared/src/*"],
      "@tasknote/ui": ["packages/ui/src/index.ts"],
      "@tasknote/ui/*": ["packages/ui/src/*"]
    }
  }
}

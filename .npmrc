# Flat node_modules so electron-builder can resolve transitive deps
# (pnpm's symlinked virtual store leaves e.g. electron-updater's fs-extra
# out of the packaged asar, crashing the app at boot).
node-linker=hoisted

# Express 4 requires path-to-regexp@0.1.x but NestJS pulls v8; hoisting put v8 at
# the root where Express's own resolution found it first ("pathRegexp is not a
# function" at boot in the packaged app). Keeping it unhoisted forces every
# consumer to resolve its own nested copy.
hoist-pattern[]=!path-to-regexp
